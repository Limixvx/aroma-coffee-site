@model List<AromaCoffee.Models.Order>

@{
    ViewData["Title"] = "Усі замовлення";
}

<h2 class="mb-4">Усі замовлення</h2>

@if (Model == null || Model.Count == 0)
{
    <p>Замовлень поки немає.</p>
}
else
{
    <div class="orders-list">
        @foreach (var order in Model)
        {
            <div class="order-card">
                <div class="order-card-header">
                    <div>
                        <h3>Замовлення #@order.Id</h3>
                        <p><strong>Клієнт:</strong> @order.CustomerName</p>
                        <p><strong>Дата:</strong> @order.OrderDate.ToString("dd.MM.yyyy HH:mm")</p>
                    </div>

                        <div class="order-status">
                          <span class="status @order.Status.ToLower()">@order.Status</span>

                           <div class="status-actions">
                            <button type="button" class="status-btn change-status"
                                    data-id="@order.Id"
                                    data-status="Нове">Нове</button>

                            <button type="button" class="status-btn change-status"
                                    data-id="@order.Id"
                                    data-status="Готується">Готується</button>

                            <button type="button" class="status-btn change-status"
                                    data-id="@order.Id"
                                    data-status="Доставляється">Доставляється</button>

                            <button type="button" class="status-btn change-status"
                                    data-id="@order.Id"
                                    data-status="Виконано">Виконано</button>

                            <button type="button" class="status-btn cancel-btn change-status"
                                    data-id="@order.Id"
                                    data-status="Скасовано">Скасовано</button>
                        </div>
                    </div>
                </div>

                <div class="order-card-body">
                    <p><strong>Телефон:</strong> @order.Phone</p>
                    <p><strong>Адреса:</strong> @order.Address</p>
                    <p><strong>Оплата:</strong> @order.PaymentMethod</p>
                    <p><strong>Сума:</strong> @order.TotalAmount грн</p>

                    <div class="order-items">
                        <strong>Товари:</strong>
                        <ul>
                            @foreach (var item in order.OrderItems)
                            {
                                <li>@item.ProductName — @item.Quantity шт. — @item.Price грн</li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        }
    </div>
}

                    <style>
    .orders-list {
        display: flex;
        flex-direction: column;
        gap: 25px;
        margin-top: 25px;
    }

    .order-card {
        background: #fff;
        border-radius: 20px;
        padding: 25px 30px;
        box-shadow: 0 6px 18px rgba(0,0,0,0.08);
        border-left: 8px solid #6f4e37;
    }

    .order-card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 20px;
        margin-bottom: 20px;
        border-bottom: 1px solid #eee;
        padding-bottom: 15px;
    }

    .order-card-header h3 {
        margin: 0 0 10px 0;
        color: #4b2e2e;
    }

    .order-card-header p {
        margin: 4px 0;
    }

    .order-status span {
        display: inline-block;
        background: #f3e5dc;
        color: #6f4e37;
        font-weight: 700;
        padding: 8px 16px;
        border-radius: 12px;
    }

    .order-card-body p {
        margin: 8px 0;
        font-size: 16px;
    }

    .order-items {
        margin-top: 15px;
        background: #faf7f5;
        border-radius: 14px;
        padding: 15px 20px;
    }

    .order-items ul {
        margin: 10px 0 0 20px;
        padding: 0;
    }

    .order-items li {
        margin-bottom: 8px;
    }

    .status.нове {
    background: #ffe0b2;
    color: #e65100;
}

.status.готується {
    background: #fff9c4;
    color: #f57f17;
}

.status.доставляється {
    background: #bbdefb;
    color: #0d47a1;
}

.status.виконано {
    background: #c8e6c9;
    color: #1b5e20;
}

.status.скасовано {
    background: #ffcdd2;
    color: #b71c1c;
}

.status-actions {
    margin-top: 12px;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}

.status-btn {
    border: none;
    background: #6f4e37;
    color: white;
    padding: 8px 14px;
    border-radius: 10px;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    transition: 0.2s;
}

.status-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
}

.cancel-btn {
    background: #b71c1c;
}

</style>

    <script>
document.querySelectorAll(".change-status").forEach(btn => {
    btn.addEventListener("click", async function () {
        const id = this.dataset.id;
        const status = this.dataset.status;

        const formData = new FormData();
        formData.append("id", id);
        formData.append("status", status);

        const response = await fetch('/Admin/UpdateStatus', {
            method: 'POST',
            body: formData
        });

        const result = await response.json();

        if (result.success) {
            const card = this.closest(".order-card");
            const statusSpan = card.querySelector(".status");

            statusSpan.textContent = result.newStatus;
            statusSpan.className = "status " + result.newStatus.toLowerCase();

            // підсвітити активну кнопку
            card.querySelectorAll(".change-status").forEach(b => {
                b.style.opacity = "0.5";
            });

            this.style.opacity = "1";
        }
    });
});
</script>