@model AromaCoffee.ViewModels.CheckoutViewModel

@{
    ViewData["Title"] = "Оформлення замовлення";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow p-4">
            <div style="margin-left: 150px;">

            <div class="card shadow-lg p-4">
                <h2 class="text-center mb-4">Оформлення замовлення</h2>

                <form asp-action="Checkout" method="post">

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="CustomerName" class="form-label"></label>
                        <input asp-for="CustomerName" class="form-control" placeholder="Введіть ім’я" />
                        <span asp-validation-for="CustomerName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label"></label>
                        <input asp-for="Phone" class="form-control" placeholder="+380..." />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label"></label>
                        <input asp-for="Address" class="form-control" placeholder="Адреса доставки (необов’язково)" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="PaymentMethod" class="form-label"></label>
                        <select asp-for="PaymentMethod" class="form-select">
                            <option value="">Оберіть спосіб оплати</option>
                            <option>Готівка</option>
                            <option>Картка</option>
                        </select>
                        <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Comment" class="form-label"></label>
                        <textarea asp-for="Comment" class="form-control" rows="3" placeholder="Коментар до замовлення"></textarea>
                    </div>

                    <button type="submit" class="btn btn-lg w-100 text-white"
                            style="background-color:#6f4e37;">
                        Підтвердити замовлення
                    </button>

                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}